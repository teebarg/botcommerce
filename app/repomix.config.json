{
    "output": {
        "filePath": "../frontend-context.md",
        "style": "markdown"
    },
    "include": [
        "src/**/*.{ts,tsx,js,jsx,mdx}"
    ],
    "ignore": [
        ".git",
        ".next",
        "node_modules",
        "out",
        "build",
        "dist",
        "coverage",
        ".turbo",
        ".env",
        ".env.*",
        "package-lock.json",
        "pnpm-lock.yaml",
        "yarn.lock",
        "**/*.test.*",
        "**/*.spec.*",
        "public/images/**",
        "public/icons/**",
        "public/fonts/**",
        ".vercel",
        ".vscode",
        ".idea"
    ]
}