{
    "output": {
        "filePath": "frontend-context.md",
        "style": "markdown"
    },
    "include": [
        "app/**/*.{ts,tsx,js,jsx,mdx}",
        "src/**/*.{ts,tsx,js,jsx,mdx}",
        "components/**/*.{ts,tsx,js,jsx}",
        "lib/**/*.{ts,tsx,js,jsx}",
        "hooks/**/*.{ts,tsx,js,jsx}",
        "providers/**/*.{ts,tsx,js,jsx}",
        "utils/**/*.{ts,tsx,js,jsx}",
        "types/**/*.{ts,tsx}",
        "public/locales/**/*.json",
        "*.json",
        "*.md"
    ],
    "ignore": [
        ".git",
        ".next",
        "node_modules",
        "out",
        "build",
        "dist",
        "coverage",
        ".turbo",
        ".env",
        ".env.*",
        "package-lock.json",
        "pnpm-lock.yaml",
        "yarn.lock",
        "**/*.test.*",
        "**/*.spec.*",
        "public/images/**",
        "public/icons/**",
        "public/fonts/**",
        ".vercel",
        ".vscode",
        ".idea",
        "app/repomix.config.json",
        "app/biome.json"
    ]
}