{
    "name": "shop-frontend",
    "version": "1.0.0",
    "private": true,
    "author": "Adeniyi <neyostica2000@yahoo.com> (https://www.niyi.com.ng)",
    "description": "A robust e-commerce storefront built with Tanstack",
    "keywords": [
        "commerce",
        "tanstack",
        "react"
    ],
    "type": "module",
    "scripts": {
        "dev-debug": "echo 'Debug mode - container will stay alive' && tail -f /dev/null",
        "dev": "cross-env NODE_OPTIONS=--use-system-ca vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "test": "vitest run",
        "format": "biome format",
        "lint": "biome lint",
        "check": "biome check",
        "start": "node .output/server/index.mjs",
        "generate:api": "powershell -Command \"$env:NODE_TLS_REJECT_UNAUTHORIZED='0'; npx openapi-zod-client 'https://api.shop.localhost/api/openapi.json' -o types2.ts\""
    },
