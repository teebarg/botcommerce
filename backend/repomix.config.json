{
    "output": {
        "filePath": "../backend-context.md"
    },
    "include": [
        "app/**/*.py"
    ],
    "ignore": {
        "useGitignore": true,
        "useDefaultPatterns": true,
        "customPatterns": [
            ".git",
            "__pycache__",
            "venv",
            ".env",
            "app/static/**",
            "app/tests/**"
        ]
    }
}