{
    "output": {
        "filePath": "backend-context.md"
    },
    "include": [
        "app/*.py",
        "app/routers/**/*.py",
        "app/models/**/*.py",
        "app/services/**/*.py",
        "app/api/**/*.py",
        "app/core/**/*.py",
        "app/email-templates/**/*.py",
        "app/email-templates/**/*.html",
        "app/lib/**/*.py",
        "app/schemas/**/*.py",
        "prisma/**",
        "pyproject.toml"
    ],
    "ignore": [
        "node_modules",
        ".git",
        "__pycache__",
        "venv",
        ".env",
        "dist",
        "build",
        "app/tests",
        "scripts",
        "repomix.config.json"
    ]
}